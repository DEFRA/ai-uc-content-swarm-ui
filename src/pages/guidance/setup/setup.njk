{% extends "common/layout.njk" %}

{% block title %}
  <title>Setup: {{ run.name }} - {{ serviceName }}</title>
{% endblock %}

{% from "common/status-tag.njk" import contextStatus %}
{% block content %}
    <div class="govuk-grid-row">
      <div class="govuk-grid-column-two-thirds">
        <h1 class="govuk-heading-xl">{{ run.name }}</h1>

        <h2 class="govuk-heading-m">Settings</h2>
        <dl class="govuk-summary-list">
          <div class="govuk-summary-list__row">
            <dt class="govuk-summary-list__key">
              Run name
            </dt>
            <dd class="govuk-summary-list__value">
              {{ run.name }}
            </dd>
          </div>
        </dl>

        <h2 class="govuk-heading-m">Supporting Context</h2>

        {% if contexts.length > 0 %}
          <h3 class="govuk-heading-s">Uploaded</h3>
          <div class="govuk-inset-text">
            <table class="govuk-table">
              <thead class="govuk-table__head">
                <tr class="govuk-table__row">
                  <th scope="col" class="govuk-table__header">Title</th>
                  <th scope="col" class="govuk-table__header">Type</th>
                  <th scope="col" class="govuk-table__header">Uploaded</th>
                  <th scope="col" class="govuk-table__header">Status</th>
                </tr>
              </thead>
              <tbody class="govuk-table__body">
                {% for context in contexts %}
                  <tr class="govuk-table__row">
                    <td class="govuk-table__cell">
                      <code>{{ context.title }}</code>
                    </td>
                    <td class="govuk-table__cell">
                      {{ context.contentType }}
                    </td>
                    <td class="govuk-table__cell">
                      {{ context.createdAt | dateFilter }}
                    </td>
                    <td class="govuk-table__cell">
                      {{ contextStatus(context.status) }}
                    </td>
                  </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        {% else %}
          <p class="govuk-body">
            <em>No context uploaded yet.</em>
          </p>
        {% endif %}

        <h3 class="govuk-heading-s">Add supporting context</h3>
        <p class="govuk-body">
          Upload text-based supporting context to provide context for the AI draft. Context will be processed and attached to your run.
        </p>

        <a href="/guidance/{{ run.id }}/upload/metadata" role="button" draggable="false" class="govuk-button govuk-button--secondary" data-module="govuk-button">
          Upload context
        </a>

        <div class="govuk-inset-text govuk-!-margin-top-9">
          <h3 class="govuk-heading-s">Ready to proceed?</h3>
          <p class="govuk-body">
            When you have added all supporting context, you can execute the draft run to generate initial AI-assisted guidance.
          </p>
          <form method="POST" action="/guidance/{{ run.id }}/start">
            <button type="submit" class="govuk-button" data-module="govuk-button">
              Execute run
            </button>
          </form>
        </div>
    </div>
{% endblock %}
