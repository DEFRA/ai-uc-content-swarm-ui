{% extends "common/layout.njk" %}

{% block title %}
  <title>Upload documents - {{ serviceName }}</title>
{% endblock %}

{% block content %}
    <div class="govuk-grid-row">
      <div class="govuk-grid-column-two-thirds">
        <a href="/guidance/{{ run.id }}/setup" class="govuk-back-link">Back</a>

        <h1 class="govuk-heading-xl">Upload supporting documentation</h1>

        <p class="govuk-body">
          You are uploading documents for: <strong>{{ run.name }}</strong>
        </p>

        <!-- Upload form -->
        <form id="upload-form" class="govuk-!-margin-top-6" action="{{ uploadAction }}" method="post" enctype="multipart/form-data">
          <div class="govuk-form-group">
            <label class="govuk-label govuk-label--l" for="document-type">
              Type of content
            </label>
            <div class="govuk-hint" id="document-type-hint">
              Select the category that best describes the documents you are uploading
            </div>
            <select
              class="govuk-select"
              id="document-type"
              name="documentType"
              aria-describedby="document-type-hint"
              required
            >
              <option value="">Select a type</option>
              <option value="legislation">Legislation &amp; policy references</option>
              <option value="guidance">Existing guidance or procedures</option>
              <option value="background">Background information</option>
              <option value="other">Other supporting materials</option>
            </select>
          </div>

          <div class="govuk-form-group">
            <label class="govuk-label govuk-label--l" for="file-upload">
              Choose file
            </label>
            <div class="govuk-hint" id="file-upload-hint">
              Accepted formats: .txt, .pdf, .docx (Max 10MB)
            </div>
            <input
              class="govuk-file-upload"
              id="file-upload"
              name="file"
              type="file"
              accept=".txt,.pdf,.docx"
              aria-describedby="file-upload-hint"
              required
            />
          </div>

            <div class="govuk-form-group">
            <button type="submit" class="govuk-button" data-module="govuk-button">
              Upload
            </button>
            <button type="button" class="govuk-button govuk-button--secondary" data-module="govuk-button" id="cancel-btn">
              Cancel
            </button>
          </div>
        </form>
        <p class="govuk-body govuk-!-margin-top-9">
          <a href="/" class="govuk-link">Back to start</a>
        </p>
      </div>
    </div>
{% endblock %}
