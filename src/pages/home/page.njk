{% extends "common/layout.njk" %}

{% block title %}
  <title>AI guidance drafting tool - {{ serviceName }}</title>
{% endblock %}

{% block content %}
    <h1 class="govuk-heading-xl">AI guidance drafting tool</h1>
    <p class="govuk-body">Use this service to create AI-generated draft guidance for UC content designers</p>
    <p class="govuk-body">The tool will generate draft content following GOV.UK style principles that you can review and refine</p>


    <p class="govuk-body">This service is for:</p>
    <ul class="govuk-list govuk-list--bullet">
      <li>content designers working on UC guidance</li>
      <li>users familiar with GOV.UK content principles</li>
    </ul>

    <h2 class="govuk-heading-m">Before you start</h2>
    <p class="govuk-body">
      You should be familiar with <a href="https://www.gov.uk/guidance/style-guide" class="govuk-link" target="_blank" rel="noopener noreferrer">GOV.UK style guide</a> 
    </p>

    <a href="/guidance/new" role="button" draggable="false" class="govuk-button govuk-button--start" data-module="govuk-button">
      Start now
      <svg class="govuk-button__start-icon" xmlns="http://www.w3.org/2000/svg" width="17.5" height="19" viewBox="0 0 33 40" aria-hidden="true" focusable="false">
        <path fill="currentColor" d="M0 0h13l20 20-20 20H0l20-20z"/>
      </svg>
    </a>
{% endblock %}